{
  "name": "@plimeor/anchor-web",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ark-ui/solid": "^5.37.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/literata": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "@plimeor/anchor-editor": "workspace:*",
    "@tanstack/solid-query": "^5.100.14",
    "@tanstack/solid-router": "^1.170.10",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-solid": "^0.500.0",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.168.13",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.6"
  },
  "scripts": {
    "build": "vite build",
    "check": "vite build && tsc --noEmit -p tsconfig.json",
    "dev": "bun scripts/dev.ts",
    "dev:core": "cargo run -p anchor-core --bin anchor-cli -- serve --vault ../desktop/demo/vault --http 127.0.0.1:4317",
    "dev:web": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "test": "bun test --conditions browser src && cargo build -p anchor-core --bin anchor-cli && ANCHOR_HTTP_IT=1 bun test src/backend/__tests__/http-integration.test.ts",
    "test:e2e": "bun scripts/e2e.ts",
    "test:e2e:editor": "bun scripts/e2e.ts editor",
    "test:e2e:editor:webview": "bun scripts/e2e.ts editor-webview"
  }
}
