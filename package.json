{
  "name": "labs",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "scripts": {
    "check": "tsgo --noEmit",
    "format": "biome format --write",
    "lint": "biome check --write",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
