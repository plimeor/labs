{
  "name": "labs",
  "private": true,
  "catalog": {
    "@standard-schema/spec": "^1.1.0",
    "@valibot/to-json-schema": "^1.6.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "^1.3.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "format": "biome format --write",
    "link-package": "bun run scripts/link-package.ts",
    "lint": "biome check --write",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
