{
  "description": "Note gateway and Codex runner utilities for agent workflows",
  "homepage": "https://github.com/plimeor/labs/tree/main/packages/note-kit",
  "name": "@plimeor/note-kit",
  "type": "module",
  "types": "./src/index.ts",
  "version": "0.1.3",
  "bin": {
    "note-gateway": "./src/note-gateway/cli.ts"
  },
  "bugs": {
