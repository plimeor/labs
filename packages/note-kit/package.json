    "./note-gateway/cli": "./src/note-gateway/cli.ts"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": "packages/note-kit",
    "type": "git",
    "url": "git+https://github.com/plimeor/labs.git"
  },
  "scripts": {
    "lint": "biome check src",
    "prepack": "bun src/note-gateway/cli.ts --help >/dev/null"
